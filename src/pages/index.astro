  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://hightidemarketing.com/#organization",
        "name": "High Tide Marketing",
        "url": "https://hightidemarketing.com",
        "logo": "https://hightidemarketing.com/assets/images/logo-horizontal.png",
        "telephone": "+19122315182",
        "email": "Support@HighTideMarketing.com",
        "description": "Data-powered digital marketing agency. We identify your in-market buyers before spending a dollar — then surround them across every channel.",
        "sameAs": ["https://www.facebook.com/hightidemarketing","https://www.instagram.com/hightidemarketing","https://www.linkedin.com/company/hightidemarketing"],
        "contactPoint": { "@type": "ContactPoint", "telephone": "+19122315182", "contactType": "customer service", "email": "Support@HighTideMarketing.com" }
      },
      {
        "@type": "WebSite",
        "@id": "https://hightidemarketing.com/#website",
        "url": "https://hightidemarketing.com",
        "name": "High Tide Marketing",
        "publisher": { "@id": "https://hightidemarketing.com/#organization" }
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "What is High Tide Radar and how does it work?", "acceptedAnswer": { "@type": "Answer", "text": "High Tide Radar is our exclusive audience intelligence platform. It identifies anonymous website visitors and matches them against 200M+ verified consumer and business profiles built from 300+ behavioral, demographic, and intent attributes. We use that information to make sure every dollar you spend on marketing only reaches people who are actually in the market for your services." } },
          { "@type": "Question", "name": "How is this different from normal targeted advertising?", "acceptedAnswer": { "@type": "Answer", "text": "Normal targeting is an educated guess. You build an audience profile and hope your buyers fit it. With Radar, we know who your actual buyers are by name before we run a single ad. Every campaign runs off a verified list, not an assumption." } },
          { "@type": "Question", "name": "Does this work for B2B and B2C businesses?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. For B2B clients, Radar identifies which companies are researching your services, what competitors they are visiting, and where they are in the buying process. For B2C, we match in-market consumers based on behavior, intent, and life stage. The approach is the same. The data is tailored to your market." } },
          { "@type": "Question", "name": "What size businesses do you work with?", "acceptedAnswer": { "@type": "Answer", "text": "We work with businesses in the $2M to $20M+ range that are serious about growth and want marketing that shows a clear return. If you are tired of agencies that cannot tell you what your budget is actually producing, we should talk." } },
          { "@type": "Question", "name": "Do I have to sign a long-term contract?", "acceptedAnswer": { "@type": "Answer", "text": "Never. We work month-to-month because we believe in earning your business, not locking you in. Cancel anytime, no questions asked." } },
          { "@type": "Question", "name": "What if I have been burned by agencies before?", "acceptedAnswer": { "@type": "Answer", "text": "We hear that a lot. That is why we start with a free strategy call and no commitment until you are confident we are the right fit. Everything we build is yours from day one regardless of what happens." } }
        ]
      }
    ]
  }
  </script>
</head>
