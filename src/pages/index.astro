    <!-- THE METHOD — 8 channel cards -->
    <section class="method" aria-labelledby="method-heading">
      <div class="section-inner">
        <div class="section-header reveal">
          <span class="tag">The Method</span>
          <h2 id="method-heading">In Front of Your Warmest Buyers<br><em>Everywhere They Go.</em></h2>
          <p style="max-width:720px;margin:16px auto 0;text-align:center;font-size:16px;color:var(--text-muted);">Once Radar identifies your buyers, we make sure they see you on every platform they use. The same warm verified buyer seeing your brand on Google, Meta, TikTok, YouTube, in their inbox, and in their mailbox — until you are the only name they think of when they are ready to buy.</p>
        </div>

        <div class="method-grid">
          <div class="method-card reveal d1">
            <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/></svg></div>
            <h3>Social Ads</h3>
            <p>Paid social served to your identified buyer list — not a lookalike. Personalized to exactly where they are in the buying journey.</p>
          </div>
          <div class="method-card reveal d2">
            <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></div>
            <h3>Social Media</h3>
