---
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';

const stats = [
  {
    value: '18.37M+',
    label: 'Impressions',
    sub: 'generated across all client platforms',
    iconPath: '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  },
  {
    value: '806K',
    label: 'Video Views',
    sub: 'across client content this year',
    iconPath: '<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>',
  },
  {
    value: '6,137',
    label: 'New Followers',
    sub: 'gained for clients YTD',
    iconPath: '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>',
  },
  {
    value: '741',
    label: 'Facebook Posts',
    sub: 'published for clients YTD',
    iconPath: '<path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>',
  },
];
---
<Layout
  title="Social Media Management | High Tide Marketing"
  description="End-to-end social media management built around your in-market buyers. Strategy, content creation, posting, and paid amplification — all tied to real revenue."
  canonicalPath="/services/social-media"
>
<main>

  <!-- ══════════════════════════════════════════
       HERO — uses shared ServiceHero component
  ══════════════════════════════════════════ -->
  <ServiceHero
    eyebrow="Social Media Management"
    headline="Content That *Converts.*"
    sub="We manage your social media end-to-end — strategy, creation, posting, and paid amplification — built around the buyers most likely to pull the trigger."
    watermark="Social Media"
    stats={stats}
  />

  <!-- ══════════════════════════════════════════
       PLATFORM STRIP
  ══════════════════════════════════════════ -->
  <section class="sm-platforms" aria-label="Platforms we manage">
    <h2 class="sm-platforms-heading">Grow on the platforms that matter.</h2>
    <div class="sm-platforms-inner">

      <!-- Facebook -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
          </svg>
        </div>
        <span class="sm-platform-name">Facebook</span>
        <span class="sm-platform-type">Pages & Ads</span>
        <p class="sm-platform-desc">Still the largest social network in the world. Critical for community building, targeted ads, and reaching buyers aged 30–65 in your local market.</p>
      </div>

      <!-- Instagram -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <span class="sm-platform-name">Instagram</span>
        <span class="sm-platform-type">Reels & Feed</span>
        <p class="sm-platform-desc">The visual brand-building platform. Reels are the highest-reach format available — the right content here can land in front of thousands of people who've never heard of you.</p>
      </div>

      <!-- TikTok -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/>
          </svg>
        </div>
        <span class="sm-platform-name">TikTok</span>
        <span class="sm-platform-type">Short-Form Video</span>
        <p class="sm-platform-desc">The fastest-growing discovery platform in the world. Authenticity wins here — behind-the-scenes content and real storytelling outperform polished ads every single time.</p>
      </div>

      <!-- YouTube -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor" stroke="none"/>
          </svg>
        </div>
        <span class="sm-platform-name">YouTube</span>
        <span class="sm-platform-type">Shorts & Longform</span>
        <p class="sm-platform-desc">The world's second-largest search engine. Shorts drive discovery, longform builds trust. A strong YouTube presence turns passive viewers into convinced buyers before they ever call.</p>
      </div>

      <!-- LinkedIn -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </div>
        <span class="sm-platform-name">LinkedIn</span>
        <span class="sm-platform-type">B2B & Authority</span>
        <p class="sm-platform-desc">The go-to platform for B2B, professional services, and thought leadership. Consistent presence here builds credibility with decision-makers and referral partners in your industry.</p>
      </div>

      <!-- Google Business -->
      <div class="sm-platform-tile">
        <div class="sm-platform-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 8v4l3 3"/>
          </svg>
        </div>
        <span class="sm-platform-name">Google Business</span>
        <span class="sm-platform-type">Reviews & Posts</span>
        <p class="sm-platform-desc">Your most underutilized asset. Regular Google Business posts signal activity to the algorithm, improve local rankings, and convert high-intent searchers at the exact moment they're ready to buy.</p>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════
       SOCIAL MEDIA PHILOSOPHY
  ══════════════════════════════════════════ -->
  <section class="sm-philosophy" aria-labelledby="philosophy-heading">
    <div class="section-inner">
      <div class="sm-philosophy-grid">

        <div class="sm-philosophy-content">
          <span class="tag">Our Philosophy</span>
          <h2 id="philosophy-heading">Most of Your Followers<br>Will Never See Your Posts.</h2>
          <p>On average, less than <strong>1.8% of your followers</strong> will see any given post you publish. The algorithm isn't designed to reward your consistency — it's designed to reward content that earns attention from people who don't follow you yet.</p>
          <p>That's why we don't just manage your social accounts. We build a growth engine. Every post is engineered to expand your reach beyond your existing audience — drawing in new buyers, not just entertaining the ones you already have.</p>
          <p>With the rise of AI-generated content flooding every platform, the biggest differentiator today is <strong>authenticity</strong>. A genuine behind-the-scenes look at your brand, your team, and your process tells a story no competitor can replicate — because it's uniquely yours. We help you capture and communicate that story in a way that makes you the obvious choice in your market.</p>
        </div>

        <div class="sm-philosophy-benefits">
          <div class="sm-philosophy-stat">
            <span class="sm-philosophy-stat-val">1.8%</span>
            <span class="sm-philosophy-stat-label">Average organic reach for business accounts</span>
          </div>

          <ul class="sm-philosophy-list">
            <li>
              <div class="sm-philosophy-list-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              </div>
              <div>
                <strong>Grow your following, grow your reach</strong>
                <p>Every new follower increases the size of your organic audience for every future post, promotion, and announcement — compounding over time.</p>
              </div>
            </li>
            <li>
              <div class="sm-philosophy-list-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
              </div>
              <div>
                <strong>Cheaper than traditional media</strong>
                <p>TV, radio, magazines, and billboards can't compete on cost-per-impression. Social media reaches your exact audience at a fraction of the price — and the analytics prove it.</p>
              </div>
            </li>
            <li>
              <div class="sm-philosophy-list-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
              </div>
              <div>
                <strong>Real-time business intelligence</strong>
                <p>The backend analytics from your social channels give us data no billboard ever could — what content resonates, when your audience is active, and what drives actual sales decisions.</p>
              </div>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       THE PROBLEM — BENTO CARD GRID
  ══════════════════════════════════════════ -->
  <section class="sm-compare" aria-labelledby="compare-heading">
    <div class="section-inner">
      <div class="section-header">
        <span class="tag">The Problem</span>
        <h2 id="compare-heading">You're Posting.<br>But You're Not Growing.</h2>
        <p class="section-sub">Most businesses treat social media like a box to check. The result? Wasted hours, empty metrics, and zero ROI you can actually trace.</p>
      </div>

      <!-- Problem Cards — staggered bento grid -->
      <div class="sm-problem-grid">

        <!-- Card 1 -->
        <div class="sm-problem-card reveal">
          <div class="sm-problem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <h3>No real strategy behind the content</h3>
          <p>You're creating content every week, but without a documented strategy you're guessing. No content pillars, no funnel awareness, no posting cadence. Just noise the algorithm buries before anyone sees it.</p>
        </div>

        <!-- Card 2 — Featured (center, taller) -->
        <div class="sm-problem-card sm-problem-card--featured reveal">
          <div class="sm-problem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
          </div>
          <h3>Likes are not leads</h3>
          <p>Vanity metrics feel good until you check the bank account. Likes, shares, comments — none of it matters if it isn't converting to calls, DMs, or sales. Most content agencies optimize for applause, not revenue.</p>
          <p class="sm-problem-stat">The average business owner wastes <strong>6–8 hours per week</strong> on social media that generates zero measurable return.</p>
        </div>

        <!-- Card 3 -->
        <div class="sm-problem-card reveal">
          <div class="sm-problem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <h3>You're guessing what your audience wants</h3>
          <p>Without real audience intelligence, you're throwing content at the wall. You don't know what your ideal buyer actually responds to — so you publish and hope. That's not a strategy, that's a coin flip.</p>
        </div>

        <!-- Card 4 -->
        <div class="sm-problem-card reveal">
          <div class="sm-problem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
          </div>
          <h3>Paying for followers who never buy</h3>
          <p>Follower count is a vanity metric. If your audience isn't made up of in-market buyers, you're growing a number that doesn't move revenue. You need the right 500 people — not the wrong 50,000.</p>
        </div>

        <!-- Card 5 -->
        <div class="sm-problem-card reveal">
          <div class="sm-problem-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>No idea which posts actually drive revenue</h3>
          <p>When a customer buys, can you trace it to a specific post? Most businesses can't. That means you're flying blind — spending hours on content with zero feedback on what's actually working.</p>
        </div>

      </div><!-- /.sm-problem-grid -->

      <!-- The High Tide Way — solution strip -->
      <div class="sm-solution-strip">
        <p class="sm-solution-label">The High Tide Way</p>
        <ul class="sm-solution-list">
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Every post tied to a documented content strategy
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Content engineered to attract in-market buyers
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            High Tide Radar identifies exactly who to target
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Followers who are actively in-market and ready to buy
          </li>
          <li>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            Monthly attribution reports showing real ROI
          </li>
        </ul>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHY HTM — HIGH TIDE RADAR
  ══════════════════════════════════════════ -->
  <section class="sm-why" aria-labelledby="why-heading">
    <div class="section-inner">
      <div class="sm-why-header">
        <span class="tag">Our Advantage</span>
        <h2 id="why-heading">We Know Your Buyers <em>Before</em> You Post</h2>
        <p>Most agencies post and pray. We use High Tide Radar — our proprietary audience intelligence platform — to identify who's actively in-market for your product or service, then build content around them.</p>
      </div>
      <div class="sm-why-grid">
        <div class="sm-why-card reveal">
          <div class="sm-why-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <h3>Audience Intelligence</h3>
          <p>High Tide Radar identifies the exact people who are in-market for your service — before you spend a dollar on content or ads.</p>
        </div>
        <div class="sm-why-card reveal">
          <div class="sm-why-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
          </div>
          <h3>Data-Driven Content</h3>
          <p>Every post, every caption, every hook is built around what your buyers respond to — not what's trending on someone else's account.</p>
        </div>
        <div class="sm-why-card reveal">
          <div class="sm-why-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
              <line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>
            </svg>
          </div>
          <h3>Full Attribution</h3>
          <p>We track which posts drive leads and revenue — not just likes. You'll see exactly where your social media investment is paying off.</p>
        </div>
      </div>
      <div class="sm-why-cta">
        <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer" class="sm-why-radar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          Learn About High Tide Radar →
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHAT'S INCLUDED — CAPABILITIES
  ══════════════════════════════════════════ -->
  <section class="sm-caps" aria-labelledby="caps-heading">
    <div class="section-inner">
      <div class="section-header">
        <span class="tag">What's Included</span>
        <h2 id="caps-heading">Everything You Need to <em>Dominate</em></h2>
      </div>
      <div class="sm-caps-grid">

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Content Strategy & Calendar</h3>
          <p>30-day roadmap with themes, content pillars, hooks, and a posting schedule built around your buyer journey.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h3>Short-Form Video</h3>
          <p>Reels, TikToks, and YouTube Shorts edited for scroll-stopping engagement — with captions, music, and branded overlays.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
          </div>
          <h3>Static Graphics & Carousels</h3>
          <p>Branded graphics designed to educate, entertain, and convert — built to your brand standards on every platform.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          </div>
          <h3>Caption Copywriting</h3>
          <p>Platform-specific copy with strategic CTAs on every post. We write every word — you review and approve before anything goes live.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3>Posting & Scheduling</h3>
          <p>Consistent publishing at optimal times for your specific audience — on every platform, every week, without you lifting a finger.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>Hashtag & SEO Strategy</h3>
          <p>Organic reach optimization on every platform — the right hashtags, keywords, and signals to get discovered by people already looking.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Community Management</h3>
          <p>DMs, comments, and brand reputation handled daily. We keep your audience engaged and your brand voice consistent across every interaction.</p>
        </div>

        <div class="sm-cap-card reveal">
          <div class="sm-cap-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <h3>Monthly Analytics Reports</h3>
          <p>Clear reporting tied to business outcomes — reach, follower growth, engagement, and direct attribution. You'll always know what's working.</p>
        </div>

        <div class="sm-cap-card sm-cap-card--cta reveal">
          <div class="sm-cap-icon sm-cap-icon--gold">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Free Social Media Audit</h3>
          <p>Schedule a marketing consultation and we'll build you a custom social media report — what's working, what's broken, and exactly where the opportunity is.</p>
          <a href="/contact" class="sm-cap-cta-btn">Book Your Free Consult →</a>
        </div>

      </div>
