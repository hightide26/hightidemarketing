---
import Layout from '../../layouts/Layout.astro';
import { sanityFetch } from '../../lib/sanity';

const { slug } = Astro.params;

const page = await sanityFetch<any>(`
  *[_type == "locationPage" && slug.current == $slug][0]{
    city, state, slug,
    hero,
    introSection,
    servicesSection{ tag, heading, sub, "services": services[]->{ title, slug, hubDescription } },
    whySection,
    resultsSection,
    radarSection,
    "testimonials": testimonials[]->{ quote, authorName, authorRole, authorCompany, rating },
    faqHeading, faq,
    finalCta,
    seo
  }
`, { slug });

if (!page) return Astro.redirect('/locations', 302);

const cityState = [page.city, page.state].filter(Boolean).join(', ');
const metaTitle = page.seo?.metaTitle || `Digital Marketing Agency in ${cityState} | High Tide Marketing`;
const metaDesc  = page.seo?.metaDescription || page.hero?.subheadline || `High Tide Marketing serves ${cityState} businesses with social media, paid ads, SEO, video, and website design.`;

function parseEm(str: string = '') {
  return str.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}

const ICONS: Record<string, string> = {
  eye:        '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  trending:   '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  target:     '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  users:      '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>',
  search:     '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  activity:   '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  map:        '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
  chart:      '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  pencil:     '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>',
  check:      '<polyline points="20 6 9 17 4 12"/>',
  radar:      '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
};

function iconFor(key: string): string {
  return ICONS[key] || ICONS['activity'];
}

const heroStats = (page.hero?.stats || []).map((s: any) => ({
  value: s.value, label: s.label, sub: s.sub, iconKey: s.iconKey,
}));
---

<Layout title={metaTitle} description={metaDesc} canonicalPath={`/locations/${slug}`}>
<main>

  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <section class="loc-hero">
    <div class="loc-hero-inner section-inner">
      {page.hero?.watermark && (
        <div class="loc-hero-watermark" aria-hidden="true">{page.hero.watermark}</div>
      )}
      <div class="loc-hero-content">
        {page.hero?.eyebrow
          ? <span class="tag">{page.hero.eyebrow}</span>
          : <span class="tag">{cityState}</span>
        }
        <h1 class="loc-hero-h1" set:html={parseEm(page.hero?.headline || `Digital Marketing Agency in *${page.city}.*`)}></h1>
        <p class="loc-hero-sub">{page.hero?.subheadline || `Serving ${cityState} businesses with social media, paid ads, SEO, video, and website design — powered by High Tide Radar audience intelligence.`}</p>
        <div class="loc-hero-actions">
          <a
            href={page.hero?.ctaHref || 'https://calendly.com/hightidemarketing/strategy-call'}
            target="_blank" rel="noopener noreferrer"
            class="btn-gold"
          >
            {page.hero?.ctaLabel || `Get Your Free ${page.city} Marketing Audit →`}
          </a>
        </div>
      </div>

      {heroStats.length > 0 && (
        <div class="loc-hero-stats">
          {heroStats.map((s: any) => (
            <div class="loc-stat-card">
              <div class="loc-stat-val">{s.value}</div>
              <div class="loc-stat-label">{s.label}</div>
              {s.sub && <div class="loc-stat-sub">{s.sub}</div>}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       LOCAL INTRO
  ══════════════════════════════════════════ -->
  {page.introSection?.heading && (
    <section class="loc-intro">
      <div class="section-inner">
        <div class="loc-intro-grid">
          <div class="loc-intro-content">
            {page.introSection.tag && <span class="tag">{page.introSection.tag}</span>}
            <h2 set:html={parseEm(page.introSection.heading)}></h2>
            {(page.introSection.paragraphs || []).map((p: string) => (
              <p>{p}</p>
            ))}
          </div>
          {page.introSection.highlights?.length > 0 && (
            <div class="loc-intro-highlights">
              {page.introSection.highlights.map((h: any) => (
                <div class="loc-highlight-card reveal">
                  <div class="loc-highlight-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"
                         set:html={iconFor(h.iconKey || 'map')}>
                    </svg>
                  </div>
                  <div>
                    <strong>{h.title}</strong>
                    {h.body && <p>{h.body}</p>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       SERVICES
  ══════════════════════════════════════════ -->
  {page.servicesSection?.services?.length > 0 && (
    <section class="loc-services">
      <div class="section-inner">
        <div class="section-header" style="text-align:center;">
          {page.servicesSection.tag && <span class="tag">{page.servicesSection.tag}</span>}
          <h2 set:html={parseEm(page.servicesSection.heading || `Everything We Offer in *${page.city}*`)}></h2>
          {page.servicesSection.sub && <p class="section-sub">{page.servicesSection.sub}</p>}
        </div>
        <div class="loc-services-grid">
          {page.servicesSection.services.map((svc: any) => (
            <a href={`/services/${svc.slug?.current}`} class="loc-svc-card reveal">
              <h3>{svc.title}</h3>
              {svc.hubDescription && <p>{svc.hubDescription}</p>}
              <span class="loc-svc-cta">
                Learn More
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       WHY HTM IN THIS MARKET
  ══════════════════════════════════════════ -->
  {page.whySection?.heading && (
    <section class="loc-why">
      <div class="section-inner">
        <div class="loc-why-header">
          {page.whySection.tag && <span class="tag">{page.whySection.tag}</span>}
          <h2 set:html={parseEm(page.whySection.heading)}></h2>
          {page.whySection.sub && <p>{page.whySection.sub}</p>}
        </div>
        {page.whySection.cards?.length > 0 && (
          <div class="loc-why-grid">
            {page.whySection.cards.map((card: any) => (
              <div class="loc-why-card reveal">
                <div class="loc-why-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"
                       set:html={iconFor(card.iconKey || 'target')}>
                  </svg>
                </div>
                <h3>{card.title}</h3>
                {card.body && <p>{card.body}</p>}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       LOCAL RESULTS
  ══════════════════════════════════════════ -->
  {page.resultsSection?.stats?.length > 0 && (
    <section class="sm-results loc-results" aria-labelledby="loc-results-heading">
      <div class="section-inner">
        <div class="section-header" style="text-align:center;">
          {page.resultsSection.tag && <span class="tag">{page.resultsSection.tag}</span>}
          <h2 id="loc-results-heading" set:html={parseEm(page.resultsSection.heading || `Results We've Delivered in *${page.city}*`)}></h2>
          {page.resultsSection.sub && <p class="sm-results-sub">{page.resultsSection.sub}</p>}
        </div>
        <div class="sm-results-grid">
          {page.resultsSection.stats.map((stat: any) => (
            <div class="sm-result-card reveal">
              <div class="sm-result-value">{stat.value}</div>
              <div class="sm-result-label">{stat.label}</div>
              {stat.sub && <div class="sm-result-sub">{stat.sub}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       HIGH TIDE RADAR
  ══════════════════════════════════════════ -->
  <section class="loc-radar">
    <div class="section-inner">
      <div class="loc-radar-inner">
        <div class="loc-radar-content">
          <span class="tag">{page.radarSection?.tag || 'Proprietary Platform'}</span>
          <h2 set:html={parseEm(page.radarSection?.heading || `We Know Who Your *${page.city}* Buyers Are — Before We Start.`)}></h2>
          <p>{page.radarSection?.sub || `High Tide Radar is our exclusive audience intelligence platform. Before we run a single ad or post a single piece of content in ${page.city}, we identify exactly who your local buyers are — their name, company, and what they're actively researching right now.`}</p>
          <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer" class="loc-radar-cta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            {page.radarSection?.ctaLabel || 'Explore High Tide Radar'}
          </a>
        </div>
        <div class="loc-radar-visual" aria-hidden="true">
          <div class="loc-radar-ring loc-radar-ring--1"></div>
          <div class="loc-radar-ring loc-radar-ring--2"></div>
          <div class="loc-radar-ring loc-radar-ring--3"></div>
          <div class="loc-radar-dot"></div>
          <div class="loc-radar-sweep"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       TESTIMONIALS
  ══════════════════════════════════════════ -->
  {page.testimonials?.length > 0 && (
    <section class="testi" aria-labelledby="loc-testi-heading">
      <div class="section-inner">
        <div class="section-header" style="text-align:center;">
          <span class="tag">Client Results</span>
          <h2 id="loc-testi-heading">What {page.city} Businesses Say</h2>
        </div>
        <div class="testi-grid">
          {page.testimonials.map((t: any) => (
            <div class="testi-card reveal">
              <p class="testi-stars">{'★'.repeat(t.rating || 5)}</p>
              <p>"{t.quote}"</p>
              <div class="testi-card-footer">
                <div class="testi-avatar testi-avatar-sm">{(t.authorName || '?')[0]}</div>
                <div class="testi-attr">
                  <div class="testi-name">{t.authorName}</div>
                  {(t.authorRole || t.authorCompany) && (
                    <div class="testi-role">{[t.authorRole, t.authorCompany].filter(Boolean).join(', ')}</div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       FAQ
  ══════════════════════════════════════════ -->
  {page.faq?.length > 0 && (
    <section class="faq" aria-labelledby="loc-faq-heading">
      <div class="section-inner">
        <div class="faq-layout">
          <div class="faq-left">
            <span class="tag">FAQ</span>
            <h2 id="loc-faq-heading" class="faq-left h2">
              {page.faqHeading || `Questions About HTM in ${page.city}`}
            </h2>
            <p>Don't see your question? <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" style="color:var(--sky-dark);font-weight:600;">Book a call</a> and we'll walk you through it.</p>
          </div>
          <div class="faq-items">
            {page.faq.map((item: any) => (
              <details class="faq-item reveal" name="faq">
                <summary class="faq-q">{item.question}</summary>
                <div class="faq-a"><p>{item.answer}</p></div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ══════════════════════════════════════════
       FINAL CTA
  ══════════════════════════════════════════ -->
  <section class="final-cta" aria-labelledby="loc-cta-heading">
    <div class="section-inner">
      <div class="final-cta-layout">
        <div class="final-cta-content">
          <span class="tag">{page.finalCta?.tag || `Serving ${cityState}`}</span>
          <h2 id="loc-cta-heading" set:html={parseEm(page.finalCta?.heading || `Let's Grow Your ${page.city} Business — *Starting Now.*`)}></h2>
          <p>{page.finalCta?.sub || `Book a free 30-minute strategy call. We'll audit your current marketing, identify the gaps, and show you exactly what we'd do differently for your ${page.city} market.`}</p>
          <div class="final-cta-actions">
            <a
              href={page.finalCta?.primaryHref || 'https://calendly.com/hightidemarketing/strategy-call'}
              target="_blank" rel="noopener noreferrer"
              class="btn-gold"
            >
              {page.finalCta?.primaryLabel || `Book Your Free ${page.city} Strategy Call →`}
            </a>
            {(page.finalCta?.secondaryLabel || page.finalCta?.secondaryHref) && (
              <a href={page.finalCta?.secondaryHref || '/services'} class="btn-ghost">
                {page.finalCta?.secondaryLabel || 'See All Services'}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

</main>
</Layout>

<style>
/* ── Location Hero ── */
.loc-hero {
  position: relative;
  overflow: hidden;
  padding: 140px var(--px) 80px;
  background: linear-gradient(160deg, var(--navy-deep) 0%, var(--navy) 60%, #0d3350 100%);
}
.loc-hero-watermark {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: clamp(80px, 18vw, 220px);
  font-weight: 900;
  color: rgba(255,255,255,0.04);
  white-space: nowrap;
  pointer-events: none;
  letter-spacing: -0.04em;
  user-select: none;
}
.loc-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.loc-hero-content .tag { background: rgba(14,165,233,0.15); color: var(--sky); border-color: rgba(14,165,233,0.25); }
.loc-hero-h1 {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 900;
  color: #fff;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin: 20px 0 24px;
}
.loc-hero-h1 em { color: var(--sky); font-style: normal; }
.loc-hero-sub {
  font-size: 17px;
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 36px;
}
.loc-hero-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
.loc-stat-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 20px 18px;
}
.loc-stat-val {
  font-size: clamp(28px, 3.5vw, 40px);
  font-weight: 900;
  color: var(--sky);
  letter-spacing: -0.03em;
  line-height: 1;
}
.loc-stat-label {
  font-size: 13px;
  color: rgba(255,255,255,0.7);
  margin-top: 6px;
  font-weight: 600;
}
.loc-stat-sub {
  font-size: 11.5px;
  color: rgba(255,255,255,0.4);
  margin-top: 2px;
}

/* ── Local Intro ── */
.loc-intro {
  padding: 96px var(--px);
  background: var(--bg);
}
.loc-intro-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: start;
}
.loc-intro-content h2 { margin: 16px 0 24px; }
.loc-intro-content p { color: var(--text-muted); line-height: 1.7; margin-bottom: 16px; }
.loc-intro-highlights { display: flex; flex-direction: column; gap: 20px; }
.loc-highlight-card {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 20px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}
.loc-highlight-icon {
  width: 40px; height: 40px; flex-shrink: 0;
  border-radius: 8px;
  background: rgba(14,165,233,0.1);
  color: var(--sky);
  display: flex; align-items: center; justify-content: center;
}
.loc-highlight-card strong { display: block; font-size: 15px; color: var(--navy); margin-bottom: 4px; }
.loc-highlight-card p { font-size: 13.5px; color: var(--text-muted); margin: 0; line-height: 1.6; }

/* ── Services Grid ── */
.loc-services {
  padding: 96px var(--px);
  background: var(--surface);
}
.loc-services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 48px;
}
.loc-svc-card {
  display: flex;
  flex-direction: column;
  padding: 28px 24px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
}
.loc-svc-card:hover {
  box-shadow: 0 8px 32px rgba(13,59,82,0.1);
  transform: translateY(-2px);
  border-color: var(--sky);
}
.loc-svc-card h3 { font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
.loc-svc-card p { font-size: 14px; color: var(--text-muted); line-height: 1.6; flex: 1; margin: 0 0 20px; }
.loc-svc-cta {
  display: flex; align-items: center; gap: 6px;
  font-size: 13.5px; font-weight: 600; color: var(--sky);
  margin-top: auto;
}

/* ── Why HTM Section ── */
.loc-why {
  padding: 96px var(--px);
  background: var(--navy-deep);
}
.loc-why-header { text-align: center; margin-bottom: 52px; }
.loc-why-header .tag { background: rgba(14,165,233,0.15); color: var(--sky); border-color: rgba(14,165,233,0.25); }
.loc-why-header h2 { color: #fff; margin: 16px 0 12px; }
.loc-why-header h2 em { color: var(--sky); font-style: normal; }
.loc-why-header p { color: rgba(255,255,255,0.6); max-width: 560px; margin: 0 auto; }
.loc-why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.loc-why-card {
  padding: 28px 24px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  transition: background 0.2s;
}
.loc-why-card:hover { background: rgba(255,255,255,0.07); }
.loc-why-icon {
  width: 44px; height: 44px;
  border-radius: 10px;
  background: rgba(14,165,233,0.12);
  color: var(--sky);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 18px;
}
.loc-why-card h3 { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 10px; }
.loc-why-card p { font-size: 14px; color: rgba(255,255,255,0.6); line-height: 1.65; margin: 0; }

/* ── Radar Section ── */
.loc-radar {
  padding: 96px var(--px);
  background: var(--bg);
}
.loc-radar-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.loc-radar-content .tag { margin-bottom: 16px; }
.loc-radar-content h2 { margin-bottom: 20px; }
.loc-radar-content p { color: var(--text-muted); line-height: 1.7; margin-bottom: 28px; }
.loc-radar-cta {
  display: inline-flex; align-items: center; gap: 8px;
  color: var(--sky); font-weight: 600; font-size: 14.5px;
  text-decoration: none;
  transition: gap 0.2s;
}
.loc-radar-cta:hover { gap: 12px; }
/* Animated radar rings */
.loc-radar-visual {
  position: relative;
  width: 280px; height: 280px;
  margin: 0 auto;
}
.loc-radar-ring {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 1px solid rgba(14,165,233,0.2);
}
.loc-radar-ring--1 { width: 100%; height: 100%; }
.loc-radar-ring--2 { width: 66%; height: 66%; border-color: rgba(14,165,233,0.3); }
.loc-radar-ring--3 { width: 33%; height: 33%; border-color: rgba(14,165,233,0.5); }
.loc-radar-dot {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--sky);
  box-shadow: 0 0 20px var(--sky);
}
.loc-radar-sweep {
  position: absolute; top: 50%; left: 50%;
  width: 50%; height: 1px;
  background: linear-gradient(to right, var(--sky), transparent);
  transform-origin: left center;
  animation: radar-sweep 3s linear infinite;
}
@keyframes radar-sweep {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .loc-hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .loc-hero-stats { grid-template-columns: repeat(4, 1fr); }
  .loc-intro-grid { grid-template-columns: 1fr; gap: 40px; }
  .loc-services-grid { grid-template-columns: 1fr 1fr; }
  .loc-why-grid { grid-template-columns: 1fr 1fr; }
  .loc-radar-inner { grid-template-columns: 1fr; }
  .loc-radar-visual { display: none; }
}
