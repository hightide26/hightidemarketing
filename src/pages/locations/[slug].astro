---
import Layout from '../../layouts/Layout.astro';
import { sanityFetch } from '../../lib/sanity';

const { slug } = Astro.params;

const page = await sanityFetch<any>(`
  *[_type == "locationPage" && slug.current == $slug][0]{
    city, state, slug,
    hero,
    introSection,
    whySection,
    resultsSection,
    radarSection,
    faqHeading, faq,
    finalCta,
    seo
  }
`, { slug });

if (!page) return Astro.redirect('/locations', 302);

const cityState = [page.city, page.state].filter(Boolean).join(', ');
const metaTitle = page.seo?.metaTitle || `Digital Marketing Agency in ${cityState} | High Tide Marketing`;
const metaDesc  = page.seo?.metaDescription || page.hero?.subheadline || `High Tide Marketing serves ${cityState} businesses with social media, paid ads, SEO, video, and website design.`;

function parseEm(str: string = '') {
  return str.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}

const ICONS: Record<string, string> = {
  eye:      '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
  trending: '<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>',
  target:   '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  users:    '<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>',
  search:   '<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>',
  activity: '<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>',
  map:      '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>',
  chart:    '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
  check:    '<polyline points="20 6 9 17 4 12"/>',
  radar:    '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
};
function iconFor(key: string): string {
  return ICONS[key] || ICONS['activity'];
}
---

<Layout title={metaTitle} description={metaDesc} canonicalPath={`/locations/${slug}`}>
<main>

  <!-- ═══════════════════════════════════════════════════
       HERO — Same cinematic sticky video as homepage
  ═══════════════════════════════════════════════════ -->
  <div class="hero-scroll-zone">
  <section class="hero" aria-label="Hero">

    <!-- Video Background -->
    <div class="hero-bg-wrap" aria-hidden="true">
      <video class="hero-bg-video" muted playsinline preload="auto">
        <source src="/assets/videos/hero-bg.mp4" type="video/mp4">
      </video>
    </div>
    <!-- Dark Overlay -->
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Main Content -->
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">
          {page.hero?.eyebrow || `Digital Marketing · ${cityState}`}
        </p>
        <h1 class="hero-h2" set:html={parseEm(page.hero?.headline || `Digital Marketing Agency in *${page.city}.*`)}></h1>
        <p class="hero-sub">{page.hero?.subheadline || `High Tide Marketing helps ${page.city} businesses reach in-market buyers by name — before spending a single dollar on advertising. Social media, paid ads, SEO, video, and website design, all powered by High Tide Radar audience intelligence.`}</p>
        <div class="hero-ctas">
          <a href={page.hero?.ctaHref || 'https://calendly.com/hightidemarketing/strategy-call'} target="_blank" rel="noopener noreferrer" class="btn-hero">
            {page.hero?.ctaLabel || `Get Your Free ${page.city} Marketing Audit →`}
          </a>
        </div>
      </div>

      <!-- Stat Cards — same as homepage -->
      <div class="hero-visual" aria-hidden="true">
        <div class="hc-stat">
          <div class="hc-stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
          </div>
          <div class="hc-stat-body">
            <div class="hc-stat-val">$33.2M+</div>
            <div class="hc-stat-label">Revenue Generated</div>
            <div class="hc-stat-sub">across businesses managed and served</div>
          </div>
        </div>
        <div class="hc-stat">
          <div class="hc-stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <div class="hc-stat-body">
            <div class="hc-stat-val">9:1</div>
            <div class="hc-stat-label">Return on Ad Spend</div>
            <div class="hc-stat-sub">average ROAS for our clients</div>
          </div>
        </div>
        <div class="hc-stat">
          <div class="hc-stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="hc-stat-body">
            <div class="hc-stat-val">140K+</div>
            <div class="hc-stat-label">Leads Generated</div>
            <div class="hc-stat-sub">across businesses managed and served</div>
          </div>
        </div>
      </div>
    </div>

    <!-- H1 Brand Watermark — city name -->
    <div class="hero-watermark" aria-hidden="true">{page.hero?.watermark || page.city?.toUpperCase()}</div>

    <!-- CLIENT TICKER -->
    <div class="clients-ticker hero-ticker" role="region" aria-label="Trusted clients">
      <div class="ticker-scroll-wrap" aria-hidden="true">
        <div class="ticker-track">
          <div class="ticker-row">
            <span>Jordan Air</span><span class="ticker-sep">·</span>
            <span>Hendrix Air</span><span class="ticker-sep">·</span>
            <span>Carolina Conditions</span><span class="ticker-sep">·</span>
            <span>TNT Service Group</span><span class="ticker-sep">·</span>
            <span>Halderman Real Estate</span><span class="ticker-sep">·</span>
            <span>LandProz</span><span class="ticker-sep">·</span>
            <span>Farmland Company</span><span class="ticker-sep">·</span>
            <span>Farmland by Dirk</span><span class="ticker-sep">·</span>
            <span>Colten Yager</span><span class="ticker-sep">·</span>
            <span>C&amp;C Myers</span><span class="ticker-sep">·</span>
            <span>Mr. Central</span><span class="ticker-sep">·</span>
            <span>Contego International</span><span class="ticker-sep">·</span>
            <span>Rural Realty Co</span><span class="ticker-sep">·</span>
            <span>Christine Estridge</span><span class="ticker-sep">·</span>
            <span>ProHealth Chiropractic</span><span class="ticker-sep">·</span>
            <span>Spencer Family Chiropractic</span><span class="ticker-sep">·</span>
            <span>Bright Windows</span><span class="ticker-sep">·</span>
            <span>Sumner Homes</span><span class="ticker-sep">·</span>
            <span>Jordan Air</span><span class="ticker-sep">·</span>
            <span>Hendrix Air</span><span class="ticker-sep">·</span>
            <span>Carolina Conditions</span><span class="ticker-sep">·</span>
            <span>TNT Service Group</span><span class="ticker-sep">·</span>
            <span>Halderman Real Estate</span><span class="ticker-sep">·</span>
            <span>LandProz</span><span class="ticker-sep">·</span>
            <span>Farmland Company</span><span class="ticker-sep">·</span>
            <span>Farmland by Dirk</span><span class="ticker-sep">·</span>
            <span>Colten Yager</span><span class="ticker-sep">·</span>
            <span>C&amp;C Myers</span><span class="ticker-sep">·</span>
            <span>Mr. Central</span><span class="ticker-sep">·</span>
            <span>Contego International</span><span class="ticker-sep">·</span>
            <span>Rural Realty Co</span><span class="ticker-sep">·</span>
            <span>Christine Estridge</span><span class="ticker-sep">·</span>
            <span>ProHealth Chiropractic</span><span class="ticker-sep">·</span>
            <span>Spencer Family Chiropractic</span><span class="ticker-sep">·</span>
            <span>Bright Windows</span><span class="ticker-sep">·</span>
            <span>Sumner Homes</span><span class="ticker-sep">·</span>
          </div>
        </div>
      </div>
      <div class="ticker-badge">
        <span>Trusted by Growing Businesses Nationwide</span>
      </div>
    </div>

  </section>
  </div><!-- /.hero-scroll-zone -->

  <!-- ═══════════════════════════════════════════════════
       LOCAL INTRO — city-specific market context
  ═══════════════════════════════════════════════════ -->
  {page.introSection?.heading && (
    <section class="loc-intro-section">
      <div class="section-inner">
        <div class="loc-intro-grid">
          <div class="loc-intro-content reveal">
            {page.introSection.tag && <span class="tag">{page.introSection.tag}</span>}
            <h2 set:html={parseEm(page.introSection.heading)}></h2>
            {(page.introSection.paragraphs || []).map((p: string) => (
              <p>{p}</p>
            ))}
          </div>
          {page.introSection.highlights?.length > 0 && (
            <div class="loc-highlights-col">
              {page.introSection.highlights.map((h: any, i: number) => (
                <div class={`loc-highlight-card reveal d${i + 1}`}>
                  <div class="loc-highlight-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"
                         set:html={iconFor(h.iconKey || 'map')}>
                    </svg>
                  </div>
                  <div>
                    <strong>{h.title}</strong>
                    {h.body && <p>{h.body}</p>}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════
       HIGH TIDE RADAR — same as homepage
  ═══════════════════════════════════════════════════ -->
  <section class="radar" id="radar" aria-labelledby="radar-heading">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="tag">{page.radarSection?.tag || 'Proprietary Platform'}</span>
        <h2 id="radar-heading" set:html={parseEm(page.radarSection?.heading || `We Know Your ${page.city} Buyers<br>Before We Spend *a Dollar.*`)}></h2>
        <p style="max-width:720px;margin:16px auto 0;text-align:center;font-size:17px;color:var(--text-muted);">{page.radarSection?.sub || `High Tide Radar is our exclusive audience intelligence platform. Before we run a single ad or send a single email in ${page.city}, we identify exactly who your buyers are — their name, company, email, phone, and what they are actively researching right now.`}</p>
        <div style="margin-top:32px;display:flex;justify-content:center;">
          <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer" class="btn-ghost-sky">
            See How High Tide Radar Works
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        </div>
      </div>

      <div class="radar-layout">
        <div class="radar-steps">
          <div class="radar-step reveal d1">
            <div class="radar-step-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </div>
            <div>
              <h4>Identify</h4>
              <p>Radar reveals who is browsing your site — even when they never fill out a form. We match your traffic against 200M+ verified consumer and business profiles enriched with 300+ demographic, behavioral, and intent attributes, so we know who your buyers are before you spend a dollar.</p>
            </div>
          </div>
          <div class="radar-step reveal d2">
            <div class="radar-step-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div>
              <h4>Profile</h4>
              <p>Each identified visitor is matched with their contact information, company data, and behavioral signals. We know what they are researching, which competitors they have visited, and how close they are to making a decision.</p>
            </div>
          </div>
          <div class="radar-step reveal d3">
            <div class="radar-step-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
            </div>
            <div>
              <h4>Target</h4>
              <p>Verified buyers go directly into your campaigns, email sequences, and outreach. You are reaching real people with confirmed interest while that interest is at its highest — not waiting for them to raise their hand.</p>
            </div>
          </div>
        </div>

        <aside class="radar-segments reveal d2">
          <div class="radar-segments-label">Audience Intelligence</div>
          <div class="radar-segments-title">Active Segments Today</div>
          <div class="radar-segments-pulse">Live · Updated in real time</div>
          <div class="radar-segments-list">
            <div class="radar-segment-row">
              <span class="radar-segment-name">HVAC In-Market Buyers</span>
              <span class="radar-segment-count">8,941</span>
            </div>
            <div class="radar-segment-row">
              <span class="radar-segment-name">Real Estate Fence-Sitters</span>
              <span class="radar-segment-count">14,220</span>
            </div>
            <div class="radar-segment-row">
              <span class="radar-segment-name">Competitor Site Visitors</span>
              <span class="radar-segment-count">5,332</span>
            </div>
            <div class="radar-segment-row">
              <span class="radar-segment-name">Past Customers — Re-engage</span>
              <span class="radar-segment-count">2,118</span>
            </div>
            <div class="radar-segment-row">
              <span class="radar-segment-name">New Mover Homeowners</span>
              <span class="radar-segment-count">33,470</span>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       THE METHOD — 8 channel cards (same as homepage)
  ═══════════════════════════════════════════════════ -->
  <section class="method" aria-labelledby="method-heading">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="tag">The Method</span>
        <h2 id="method-heading">In Front of Your Warmest {page.city} Buyers<br><em>Everywhere They Go.</em></h2>
        <p style="max-width:720px;margin:16px auto 0;text-align:center;font-size:16px;color:var(--text-muted);">Once Radar identifies your buyers, we make sure they see you on every platform they use. The same warm verified buyer seeing your brand on Google, Meta, TikTok, YouTube, in their inbox, and in their mailbox — until you are the only name they think of when they are ready to buy.</p>
      </div>
      <div class="method-grid">
        <div class="method-card reveal d1">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/></svg></div>
          <h3>Social Ads</h3>
          <p>Paid social served to your identified buyer list — not a lookalike. Personalized to exactly where they are in the buying journey.</p>
        </div>
        <div class="method-card reveal d2">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></div>
          <h3>Social Media</h3>
          <p>Consistent organic content and community engagement that builds the authority paid ads alone can't create — so your name is already trusted when buyers are ready.</p>
        </div>
        <div class="method-card reveal d3">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div>
          <h3>YouTube Ads</h3>
          <p>Pre-roll, skippable, and non-skippable formats keeping you visible on the world's second-largest search engine throughout the entire decision process.</p>
        </div>
        <div class="method-card reveal d4">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 8l9 6 9-6"/></svg></div>
          <h3>Direct Mail</h3>
          <p>Verified digital audiences turned into physical mail delivered within 48 hours — a tangible touchpoint while buyers are actively considering. A channel most competitors have abandoned.</p>
        </div>
        <div class="method-card reveal d1">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
          <h3>Email</h3>
          <p>Behavior-triggered sequences. When Radar detects intent, we put a personalized message in their inbox while interest is at its highest — turning warm signals into booked appointments.</p>
        </div>
        <div class="method-card reveal d2">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg></div>
          <h3>Video</h3>
          <p>Video isn't an add-on at High Tide — it's the foundation. Scripting, filming, editing, and deployment across every screen, looking like the business buyers already believe you to be.</p>
        </div>
        <div class="method-card reveal d3">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
          <h3>Search Optimization</h3>
          <p>Long-term organic visibility built around the exact search terms your identified buyers are already using. Technical SEO, content, local authority, and links compounding over time.</p>
        </div>
        <div class="method-card reveal d4">
          <div class="method-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><path d="M8 21h8M12 17v4"/></svg></div>
          <h3>Websites</h3>
          <p>High-converting websites built to turn identified buyers into booked appointments. Fast, modern, and designed around the exact journey your Radar audience takes before they buy.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       WHY IT WORKS — efficiency stats + comparison table
  ═══════════════════════════════════════════════════ -->
  <section class="efficiency" aria-labelledby="eff-heading">
    <div class="section-inner">
      <div class="section-header reveal">
        <span class="tag">Why It Works</span>
        <h2 id="eff-heading">Spend Less on People<br>Who Will <em>Never Buy.</em></h2>
        <p style="margin:16px auto 0;font-size:16.5px;color:var(--text-muted);line-height:1.7;">Stop wasting budget on cold audiences. The same spend goes further — reinvested into better creative, higher-quality campaigns, and results that compound.</p>
      </div>
      <div class="eff-stats">
        <div class="eff-stat reveal d1"><div class="eff-stat-val">9:1</div><div class="eff-stat-label">Avg. ROAS</div></div>
        <div class="eff-stat reveal d2"><div class="eff-stat-val">40%</div><div class="eff-stat-label">Less Waste</div></div>
        <div class="eff-stat reveal d3"><div class="eff-stat-val">200M+</div><div class="eff-stat-label">Buyer Profiles</div></div>
      </div>
      <div class="eff-table reveal">
        <div class="eff-table-head">
          <div>Compared to traditional agencies</div>
          <div>The Old Way</div>
          <div>High Tide Enabled</div>
        </div>
        <div class="eff-row"><div class="eff-row-label">Audience Targeting</div><div class="eff-row-old">Broad Guesses</div><div class="eff-row-new">Verified Buyer List</div></div>
        <div class="eff-row"><div class="eff-row-label">Budget Efficiency</div><div class="eff-row-old">40% Wasted</div><div class="eff-row-new">Concentrated on Warm Prospects</div></div>
        <div class="eff-row"><div class="eff-row-label">Buyer Intelligence</div><div class="eff-row-old">None</div><div class="eff-row-new">Name, Company, Intent Signals</div></div>
        <div class="eff-row"><div class="eff-row-label">Attribution</div><div class="eff-row-old">Black Box</div><div class="eff-row-new">Real-Time Dashboard</div></div>
        <div class="eff-row"><div class="eff-row-label">Contract Terms</div><div class="eff-row-old">Lock-In Required</div><div class="eff-row-new">Month-to-Month</div></div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       WHY THIS MARKET — city-specific cards from Sanity
  ═══════════════════════════════════════════════════ -->
  {page.whySection?.heading && (
    <section class="whyhtm-loc" aria-labelledby="why-market-heading">
      <div class="section-inner">
        <div class="section-header reveal" style="text-align:center;">
          {page.whySection.tag && <span class="tag" style="margin:0 auto;">{page.whySection.tag}</span>}
          <h2 id="why-market-heading" set:html={parseEm(page.whySection.heading)}></h2>
          {page.whySection.sub && <p style="max-width:600px;margin:12px auto 0;color:var(--text-muted);">{page.whySection.sub}</p>}
        </div>
        {page.whySection.cards?.length > 0 && (
          <div class="stage-grid" style="margin-top:52px;">
            {page.whySection.cards.map((card: any, i: number) => (
              <div class={`stage-card reveal d${i + 1}`}>
                <div class="stage-num">0{i + 1}</div>
                <h3>{card.title}</h3>
                {card.body && <p>{card.body}</p>}
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════
       PROCESS — same 3 steps as homepage
  ═══════════════════════════════════════════════════ -->
  <section class="process" id="process" aria-labelledby="process-heading">
    <div class="section-inner">
      <div class="section-header reveal" style="text-align:center;">
