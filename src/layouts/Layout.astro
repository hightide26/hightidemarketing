---
import { sanityFetch } from '../lib/sanity';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath?: string;
}
const {
  title,
  description,
  ogImage = 'https://hightidemarketing.com/assets/images/og-image.jpg',
  canonicalPath = '',
} = Astro.props;
const canonical = `https://hightidemarketing.com${canonicalPath}`;

// Dynamic locations for nav dropdown — auto-populates when new location docs are published
const navLocations = await sanityFetch<{city: string; state: string; slug: {current: string}}[]>(
  `*[_type == "locationPage"] | order(city asc) { city, state, slug }`,
  {}
);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- Canonical -->
  <link rel="canonical" href={canonical}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/favicon.svg">
  <meta name="theme-color" content="#0d2137">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/assets/css/main.css">

  <!-- GHL booking widget -->
  <script src="https://link.msgsndr.com/js/form_embed.js" async></script>
</head>
<body>
<div class="page-guard">

  <!-- NAV -->
  <header class="nav" id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="High Tide Marketing home">
        <img class="logo-color" src="/assets/images/logo-color.svg"  alt="High Tide Marketing" width="160" height="53">
        <img class="logo-white" src="/assets/images/logo-white.webp" alt="High Tide Marketing" width="160" height="53">
      </a>
      <nav class="nav-links" aria-label="Main navigation">
        <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer">High Tide Radar</a>

        <!-- ── Services Mega Menu ── -->
        <div class="nav-mega-wrap" id="nav-mega-services">
          <button class="nav-mega-btn" aria-expanded="false" aria-haspopup="true">
            Services
            <svg class="mega-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>

          <div class="mega-panel">
            <div class="mega-panel-inner">

              <!-- Service Links Grid -->
              <div class="mega-services-grid">
                <a href="/services/social-media" class="mega-svc">
                  <div class="mega-svc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                  </div>
                  <div class="mega-svc-body">
                    <div class="mega-svc-name">Social Media</div>
                    <div class="mega-svc-desc">Content strategy, management &amp; paid social</div>
                  </div>
                </a>
                <a href="/services/video" class="mega-svc">
                  <div class="mega-svc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
                  </div>
                  <div class="mega-svc-body">
                    <div class="mega-svc-name">Video &amp; Photography</div>
                    <div class="mega-svc-desc">Videography, editing &amp; visual content</div>
                  </div>
                </a>
                <a href="/services/websites" class="mega-svc">
                  <div class="mega-svc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                  </div>
                  <div class="mega-svc-body">
                    <div class="mega-svc-name">Website Design</div>
                    <div class="mega-svc-desc">Custom sites built to rank and convert</div>
                  </div>
                </a>
                <a href="/services/paid-ads" class="mega-svc">
                  <div class="mega-svc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                  </div>
                  <div class="mega-svc-body">
                    <div class="mega-svc-name">Paid Advertising</div>
                    <div class="mega-svc-desc">Google, Meta, TikTok &amp; YouTube ads</div>
                  </div>
                </a>
                <a href="/services/seo" class="mega-svc">
                  <div class="mega-svc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  </div>
                  <div class="mega-svc-body">
                    <div class="mega-svc-name">SEO</div>
                    <div class="mega-svc-desc">Organic rankings that drive real buyers</div>
                  </div>
                </a>
              </div>

              <!-- High Tide Radar Featured Card -->
              <div class="mega-feature">
                <div class="mega-feature-eyebrow">Proprietary Platform</div>
                <div class="mega-feature-title">High Tide Radar</div>
                <p class="mega-feature-desc">Know who your buyers are before you spend a dollar. Our audience intelligence platform drives every campaign we run.</p>
                <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer" class="mega-feature-cta">
                  Explore Radar
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>

            </div><!-- /.mega-panel-inner -->

            <div class="mega-panel-footer">
              <a href="/services" class="mega-all-link">
                View All Services
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          </div><!-- /.mega-panel -->
        </div><!-- /.nav-mega-wrap -->

        <!-- ── Locations Mega Menu — dynamic from Sanity ── -->
        <div class="nav-mega-wrap" id="nav-mega-locations">
          <button class="nav-mega-btn" aria-expanded="false" aria-haspopup="true">
            Locations
            <svg class="mega-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="mega-panel mega-panel--locations">
            <div class="mega-panel-inner">
              <div class="mega-locations-list">
                {navLocations.length > 0 ? navLocations.map((loc) => (
                  <a href={`/locations/${loc.slug.current}`} class="mega-location-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {loc.city}{loc.state ? `, ${loc.state}` : ''}
                  </a>
                )) : (
                  <p class="mega-locations-empty">Locations coming soon.</p>
                )}
              </div>
            </div>
            <div class="mega-panel-footer">
              <a href="/locations" class="mega-all-link">
                View All Locations
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            </div>
          </div>
        </div>

        <a href="/#about">About</a>
        <a href="/blog">Blog</a>
      </nav>
      <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" class="btn-gold nav-cta">Book a Strategy Call</a>
      <button class="nav-hamburger" aria-label="Open navigation menu" aria-expanded="false" id="hamburger">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- MOBILE MENU -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <button class="mobile-menu-close" id="mobile-close" aria-label="Close navigation menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <nav class="mobile-nav" aria-label="Mobile navigation">
      <a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer">High Tide Radar</a>
      <a href="/services">Services</a>
      <a href="/locations">Locations</a>
      <a href="/#about">About</a>
      <a href="/blog">Blog</a>
    </nav>
    <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" class="btn-gold">Book a Strategy Call</a>
  </div>

  <slot />

  <!-- FOOTER -->
  <footer class="footer" aria-label="Footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/assets/images/logo-horizontal.png" alt="High Tide Marketing" width="160" height="40" loading="lazy">
          <p>A data-powered digital marketing agency. We identify your in-market buyers first, then surround them across every channel.</p>
          <div class="footer-brand-badges">
            <span class="footer-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Veteran Owned
            </span>
            <span class="footer-badge">Month-to-Month</span>
          </div>
        </div>
        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            <li><a href="/services/social-media">Social Media</a></li>
            <li><a href="/services/video">Video Content</a></li>
            <li><a href="/services/websites">Website Design</a></li>
            <li><a href="/services/paid-ads">Paid Ads</a></li>
            <li><a href="/services/seo">SEO</a></li>
            <li><a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer">High Tide Radar</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="https://hightideradar.com" target="_blank" rel="noopener noreferrer">High Tide Radar</a></li>
            <li><a href="/#about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="https://calendly.com/hightidemarketing/strategy-call">Contact</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Contact</h4>
          <ul>
            <li><a href="tel:+19122315182">(912) 231-5182</a></li>
            <li><a href="mailto:Support@HighTideMarketing.com">Support@HighTideMarketing.com</a></li>
            <li><a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer">Book a Strategy Call</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p class="footer-copy">© 2026 High Tide Marketing. All rights reserved.</p>
        <div class="footer-links">
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
      </div>
      <div class="footer-wordmark-wrap" aria-hidden="true">
        <span class="footer-wordmark">HIGH TIDE MARKETING</span>
      </div>
    </div>
  </footer>

  <!-- GSAP -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer></script>
  <script src="/assets/js/main.js" defer></script>

</div><!-- /.page-guard -->
</body>
</html>
