---
/**
 * ServiceHero — shared cinematic hero for all service pages.
 * Matches the homepage and services hub exactly.
 *
 * Props:
 *   eyebrow      — small label above headline (e.g. "Social Media Management")
 *   headline     — main H1, use *word* for sky-blue <em> emphasis
 *   sub          — paragraph below headline
 *   watermark    — large ghost text in the background (e.g. "Social Media")
 *   stats        — array of { icon: string (svg path), value, label, sub }
 *   ctaLabel?    — override CTA button text (default: "Book Your Free Strategy Call →")
 *   ctaHref?     — override CTA href (default: Calendly link)
 *   videoSrc?    — override video file (default: /assets/videos/hero-bg.mp4)
 *   ticker?      — show the client ticker at the bottom (default: true)
 */

interface Stat {
  value: string;
  label: string;
  sub: string;
  iconPath: string; // SVG <path>/<polyline>/etc inner content (raw HTML string)
}

interface Props {
  eyebrow: string;
  headline: string;
  sub: string;
  watermark: string;
  stats: Stat[];
  ctaLabel?: string;
  ctaHref?: string;
  videoSrc?: string;
  ticker?: boolean;
}

const {
  eyebrow,
  headline,
  sub,
  watermark,
  stats,
  ctaLabel = 'Book Your Free Strategy Call →',
  ctaHref = 'https://calendly.com/hightidemarketing/strategy-call',
  videoSrc = '/assets/videos/hero-bg.mp4',
  ticker = true,
} = Astro.props;

// Parse *asterisks* → <em>
function parseHeadline(str: string) {
  return str.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
---

<div class="hero-scroll-zone">
<section class="hero" aria-labelledby="svc-hero-h1">

  <!-- Video background -->
  <div class="hero-bg-wrap" aria-hidden="true">
    <video class="hero-bg-video" muted playsinline preload="auto">
      <source src={videoSrc} type="video/mp4">
    </video>
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Main content -->
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">{eyebrow}</p>
      <h1 id="svc-hero-h1" class="hero-h2" set:html={parseHeadline(headline)}></h1>
      <p class="hero-sub">{sub}</p>
      <div class="hero-ctas">
        <a href={ctaHref} target="_blank" rel="noopener noreferrer" class="btn-hero">
          {ctaLabel}
        </a>
      </div>
    </div>

    <!-- Stat cards — right column -->
    <div class="hero-visual" aria-hidden="true">
      {stats.map((stat) => (
        <div class="hc-stat">
          <div class="hc-stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={stat.iconPath}></svg>
          </div>
          <div class="hc-stat-body">
            <div class="hc-stat-val">{stat.value}</div>
            <div class="hc-stat-label">{stat.label}</div>
            <div class="hc-stat-sub">{stat.sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Ghost watermark -->
  <h2 class="hero-watermark" aria-hidden="true">{watermark}</h2>

  <!-- Client ticker -->
  {ticker && (
    <div class="clients-ticker hero-ticker" role="region" aria-label="Trusted clients">
      <div class="ticker-scroll-wrap" aria-hidden="true">
        <div class="ticker-track">
          <div class="ticker-row">
            <span>Jordan Air</span><span class="ticker-sep">·</span>
            <span>Hendrix Air</span><span class="ticker-sep">·</span>
            <span>Carolina Conditions</span><span class="ticker-sep">·</span>
            <span>TNT Service Group</span><span class="ticker-sep">·</span>
            <span>Halderman Real Estate</span><span class="ticker-sep">·</span>
            <span>LandProz</span><span class="ticker-sep">·</span>
            <span>Farmland Company</span><span class="ticker-sep">·</span>
            <span>Farmland by Dirk</span><span class="ticker-sep">·</span>
            <span>Colten Yager</span><span class="ticker-sep">·</span>
            <span>C&amp;C Myers</span><span class="ticker-sep">·</span>
            <span>Mr. Central</span><span class="ticker-sep">·</span>
            <span>Contego International</span><span class="ticker-sep">·</span>
            <span>Rural Realty Co</span><span class="ticker-sep">·</span>
            <span>Christine Estridge</span><span class="ticker-sep">·</span>
            <span>ProHealth Chiropractic</span><span class="ticker-sep">·</span>
            <span>Spencer Family Chiropractic</span><span class="ticker-sep">·</span>
            <span>Bright Windows</span><span class="ticker-sep">·</span>
            <span>Sumner Homes</span><span class="ticker-sep">·</span>
            <!-- Duplicate for seamless loop -->
            <span>Jordan Air</span><span class="ticker-sep">·</span>
            <span>Hendrix Air</span><span class="ticker-sep">·</span>
            <span>Carolina Conditions</span><span class="ticker-sep">·</span>
            <span>TNT Service Group</span><span class="ticker-sep">·</span>
            <span>Halderman Real Estate</span><span class="ticker-sep">·</span>
            <span>LandProz</span><span class="ticker-sep">·</span>
            <span>Farmland Company</span><span class="ticker-sep">·</span>
            <span>Farmland by Dirk</span><span class="ticker-sep">·</span>
            <span>Colten Yager</span><span class="ticker-sep">·</span>
            <span>C&amp;C Myers</span><span class="ticker-sep">·</span>
            <span>Mr. Central</span><span class="ticker-sep">·</span>
            <span>Contego International</span><span class="ticker-sep">·</span>
            <span>Rural Realty Co</span><span class="ticker-sep">·</span>
            <span>Christine Estridge</span><span class="ticker-sep">·</span>
            <span>ProHealth Chiropractic</span><span class="ticker-sep">·</span>
            <span>Spencer Family Chiropractic</span><span class="ticker-sep">·</span>
            <span>Bright Windows</span><span class="ticker-sep">·</span>
            <span>Sumner Homes</span><span class="ticker-sep">·</span>
          </div>
        </div>
      </div>
      <div class="ticker-badge" aria-hidden="true">
        <span>TRUSTED BY GROWING BUSINESSES NATIONWIDE</span>
      </div>
    </div>
  )}

</section>
</div>
