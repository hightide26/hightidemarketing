---
import Layout from '../../layouts/Layout.astro';
import { sanityFetch } from '../../lib/sanity';

const { slug } = Astro.params;

// GROQ query — fetch this service page + dereference testimonials
const page = await sanityFetch<any>(`
  *[_type == "servicePage" && slug.current == $slug][0]{
    title,
    slug,
    hubDescription,
    hero,
    platforms,
    radarBlurb,
    comparison,
    capabilities,
    tiers,
    "testimonials": testimonials[]->{
      quote,
      authorName,
      authorRole,
      authorCompany,
      rating
    },
    faq,
    seo
  }
`, { slug });

// 404 if no matching document in Sanity
if (!page) {
  return Astro.redirect('/services', 302);
}

const title = page.seo?.metaTitle || `${page.title} | High Tide Marketing`;
const description = page.seo?.metaDescription || page.hero?.subheadline || '';

// Parse *asterisks* in headline → <em> tags
function parseHeadline(str: string = '') {
  return str.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
---

<Layout title={title} description={description} canonicalPath={`/services/${slug}`}>
<main>

  <!-- ── HERO ── -->
  <section class="svc-pg-hero" aria-labelledby="svc-hero-heading">
    <div class="svc-pg-hero-overlay" aria-hidden="true"></div>
    <div class="svc-pg-hero-inner">
      {page.hero?.tag && <span class="tag">{page.hero.tag}</span>}
      <h1 id="svc-hero-heading" set:html={parseHeadline(page.hero?.headline || page.title)}></h1>
      {page.hero?.subheadline && (
        <p class="svc-pg-hero-sub">{page.hero.subheadline}</p>
      )}
      <div class="svc-pg-hero-ctas">
        <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" class="btn-gold">
          Book a Free Strategy Call →
        </a>
        <a href="/services" class="btn-ghost">See All Services</a>
      </div>
    </div>
  </section>

  <!-- ── PLATFORM STRIP (optional) ── -->
  {page.platforms?.length > 0 && (
    <section class="sm-platforms" aria-label="Platforms">
      <div class="sm-platforms-inner">
        {page.platforms.map((p: any) => (
          <div class="sm-platform-tile">
            <div class="sm-platform-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <span class="sm-platform-name">{p.name}</span>
            {p.type && <span class="sm-platform-type">{p.type}</span>}
          </div>
        ))}
        {page.radarBlurb && (
          <div class="sm-platform-radar">
            <div class="sm-platform-radar-label">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>
              </svg>
              High Tide Radar
            </div>
            <p>{page.radarBlurb}</p>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- ── COMPARISON (optional) ── -->
  {(page.comparison?.oldItems?.length > 0 || page.comparison?.newItems?.length > 0) && (
    <section class="sm-compare" aria-labelledby="compare-heading">
      <div class="section-inner">
        <div class="section-header">
          <span class="tag">Why It Matters</span>
          <h2 id="compare-heading">There Is a Better Way to Do This</h2>
        </div>
        <div class="sm-compare-grid">
          <div class="sm-compare-col sm-compare-col--old">
            <div class="sm-compare-label">{page.comparison.oldLabel || 'Traditional Marketing'}</div>
            <ul class="sm-compare-list">
              {page.comparison.oldItems.map((item: string) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="sm-compare-col sm-compare-col--new">
            <div class="sm-compare-label">{page.comparison.newLabel || 'The High Tide Way'}</div>
            <ul class="sm-compare-list">
              {page.comparison.newItems.map((item: string) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── CAPABILITIES (optional) ── -->
  {page.capabilities?.length > 0 && (
    <section class="sm-caps" aria-labelledby="caps-heading">
      <div class="section-inner">
        <div class="section-header">
          <span class="tag">What's Included</span>
          <h2 id="caps-heading">Everything You Need to <em>Dominate</em></h2>
        </div>
        <div class="sm-caps-grid">
          {page.capabilities.map((cap: any) => (
            <div class="sm-cap-card reveal">
              <div class="sm-cap-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
              </div>
              <h3>{cap.title}</h3>
              <p>{cap.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── PRICING TIERS (optional) ── -->
  {page.tiers?.length > 0 && (
    <section class="sm-tiers" aria-labelledby="tiers-heading">
      <div class="section-inner">
        <div class="section-header" style="text-align:center;">
          <span class="tag">Pricing</span>
          <h2 id="tiers-heading">Choose the Right Level</h2>
          <p>All tiers include month-to-month flexibility. No contracts.</p>
        </div>
        <div class="sm-tiers-grid">
          {page.tiers.map((tier: any) => (
            <div class={`sm-tier-card${tier.featured ? ' sm-tier-card--featured' : ''}`}>
              {tier.badge && <span class="sm-tier-badge">{tier.badge}</span>}
              <div>
                <div class="sm-tier-name">{tier.name}</div>
                {tier.tagline && <div class="sm-tier-tagline">{tier.tagline}</div>}
              </div>
              {tier.features?.length > 0 && (
                <ul class="sm-tier-list">
                  {tier.features.map((f: string) => (
                    <li>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                      {f}
                    </li>
                  ))}
                </ul>
              )}
              <div class="sm-tier-cta">
                <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" class={tier.featured ? 'btn-gold' : 'btn-ghost'}>
                  Schedule a Call for Pricing →
                </a>
              </div>
            </div>
          ))}
        </div>
        <p class="sm-tiers-note">Month-to-month. Cancel anytime. Everything we build is yours from day one.</p>
      </div>
    </section>
  )}

  <!-- ── TESTIMONIALS (optional) ── -->
  {page.testimonials?.length > 0 && (
    <section class="testi" aria-labelledby="testi-heading">
      <div class="section-inner">
        <div class="section-header" style="text-align:center;">
          <span class="tag">Client Results</span>
          <h2 id="testi-heading">What Our Clients Say</h2>
        </div>
        <div class="testi-grid">
          {page.testimonials.map((t: any) => (
            <div class="testi-card reveal">
              <p class="testi-stars">{'★'.repeat(t.rating || 5)}</p>
              <p>"{t.quote}"</p>
              <div class="testi-card-footer">
                <div class="testi-avatar testi-avatar-sm">{t.authorName?.[0] || '?'}</div>
                <div class="testi-attr">
                  <div class="testi-name">{t.authorName}</div>
                  {(t.authorRole || t.authorCompany) && (
                    <div class="testi-role">{[t.authorRole, t.authorCompany].filter(Boolean).join(', ')}</div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── FAQ (optional) ── -->
  {page.faq?.length > 0 && (
    <section class="faq" aria-labelledby="faq-heading">
      <div class="section-inner">
        <div class="faq-layout">
          <div class="faq-left">
            <span class="tag">FAQ</span>
            <h2 id="faq-heading" class="faq-left h2">Questions About {page.title}</h2>
            <p>Don't see your question? <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" style="color:var(--sky-dark);font-weight:600;">Book a call</a> and we'll walk you through it.</p>
          </div>
          <div class="faq-items">
            {page.faq.map((item: any, i: number) => (
              <details class="faq-item reveal" name="faq">
                <summary class="faq-q">{item.question}</summary>
                <div class="faq-a"><p>{item.answer}</p></div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ── FINAL CTA — always shown ── -->
  <section class="final-cta" aria-labelledby="cta-heading">
    <div class="section-inner">
      <div class="final-cta-inner">
        <span class="tag">Ready to Start?</span>
        <h2 id="cta-heading">Let's Put {page.title} to Work<br>for <em>Your Business.</em></h2>
        <p>Book a free 30-minute strategy call. We'll look at your current marketing, identify the gaps, and show you exactly what we'd do differently — no pitch deck, no pressure.</p>
        <div class="final-cta-actions">
          <a href="https://calendly.com/hightidemarketing/strategy-call" target="_blank" rel="noopener noreferrer" class="btn-gold">
            Book Your Free Strategy Call →
          </a>
          <a href="/services" class="btn-ghost">See All Services</a>
        </div>
      </div>
    </div>
  </section>

</main>
</Layout>
